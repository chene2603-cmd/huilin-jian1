#include "core/json.h"
#include "core/file.h"
#include <stdio.h>

struct json_object* json_parse_file(const char* path) {
    char* text = file_read_text(path);
    if (!text) { 
        fprintf(stderr, "Failed to read JSON: %s\n", path); 
        return NULL; 
    }
    
    struct json_object* root = json_tokener_parse(text);
    file_free_text(text);
    
    if (!root) {
        fprintf(stderr, "Failed to parse JSON: %s\n", path);
    }
    
    return root;
}

struct json_object* json_parse_string(const char* str) {
    return json_tokener_parse(str);
}

struct json_object* json_get_object(struct json_object* parent, const char* key) {
    struct json_object* obj = NULL;
    if (parent && json_object_is_type(parent, json_type_object)) {
        json_object_object_get_ex(parent, key, &obj);
    }
    return obj;
}

double json_get_number(struct json_object* parent, const char* key) {
    struct json_object* obj = json_get_object(parent, key);
    if (!obj) {
        fprintf(stderr, "WARNING: JSON key '%s' not found\n", key);
        return 0.0;
    }
    
    if (json_object_is_type(obj, json_type_double)) {
        return json_object_get_double(obj);
    }
    if (json_object_is_type(obj, json_type_int)) {
        return (double)json_object_get_int(obj);
    }
    
    fprintf(stderr, "WARNING: JSON key '%s' is not a number (type: %d)\n", 
            key, json_object_get_type(obj));
    return 0.0;
}

const char* json_get_string(struct json_object* parent, const char* key) {
    struct json_object* obj = json_get_object(parent, key);
    if (!obj) {
        fprintf(stderr, "WARNING: JSON key '%s' not found\n", key);
        return "";
    }
    
    if (json_object_is_type(obj, json_type_string)) {
        return json_object_get_string(obj);
    }
    
    fprintf(stderr, "WARNING: JSON key '%s' is not a string (type: %d)\n", 
            key, json_object_get_type(obj));
    return "";
}

int json_array_length(struct json_object* array) {
    if (array && json_object_is_type(array, json_type_array)) {
        return json_object_array_length(array);
    }
    return 0;
}

struct json_object* json_array_get(struct json_object* array, int index) {
    if (array && json_object_is_type(array, json_type_array)) {
        return json_object_array_get_idx(array, index);
    }
    return NULL;
}

int json_get_vec3(struct json_object* parent, const char* key,
                  float* out_x, float* out_y, float* out_z) {
    struct json_object* arr = json_get_object(parent, key);
    if (!arr) {
        fprintf(stderr, "WARNING: JSON key '%s' not found\n", key);
        return 0;
    }
    
    if (!json_object_is_type(arr, json_type_array)) {
        fprintf(stderr, "WARNING: JSON key '%s' is not an array (type: %d)\n", 
                key, json_object_get_type(arr));
        return 0;
    }
    
    int len = json_object_array_length(arr);
    if (len < 3) {
        fprintf(stderr, "WARNING: JSON array '%s' length %d < 3\n", key, len);
        return 0;
    }
    
    *out_x = (float)json_object_get_double(json_object_array_get_idx(arr, 0));
    *out_y = (float)json_object_get_double(json_object_array_get_idx(arr, 1));
    *out_z = (float)json_object_get_double(json_object_array_get_idx(arr, 2));
    return 1;
}

void json_free(struct json_object* root) {
    if (root) {
        json_object_put(root);
    }
}